# Generá una clave segura con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Poner False en producción
DEBUG=True

# Dominio del backend en Render (sin https://)
# Ejemplo: consultorio-backend.onrender.com
ALLOWED_HOSTS=

# URL del frontend en Vercel (con https://)
# Ejemplo: https://consultorio.vercel.app
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# Base de datos PostgreSQL
DB_NAME=lawclinic
DB_USER=lawclinic_admin
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
